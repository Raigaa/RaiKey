{
  "manifest_version": 3,
  "name": "RaiKey",
  "version": "1.0.0",
  "description": "Productivity extension to execute quick actions via custom keyboard shortcuts",
  "icons": {
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png"
  },
  "permissions": [
    "tabs",
    "storage"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "commands": {
    "detach-tab": {
      "suggested_key": {
        "default": "Ctrl+Shift+U"
      },
      "description": "Detach current tab into a new window"
    },
    "duplicate-tab": {
      "suggested_key": {
        "default": "Alt+Shift+D"
      },
      "description": "Duplicate current tab"
    },
    "quick-clean": {
      "suggested_key": {
        "default": "Alt+Shift+Q"
      },
      "description": "Quick Clean (Close specific domains)"
    }
  },
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "48": "icons/icon-48.png",
      "96": "icons/icon-96.png"
    }
  },
  "options_ui": {
    "page": "src/options/options.html",
    "open_in_tab": true
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "raigaa@raikey.dev",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
